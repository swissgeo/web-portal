{
    "$schema": "https://turborepo.dev/schema.json",
    "tasks": {
        "build": {
            "outputs": ["dist/**"],
            "dependsOn": ["^build"]
        },
        "build-libs": {
            "outputs": ["dist/**"],
            "dependsOn": ["^build-libs"]
        },
        "build-libs:dev": {
            "outputs": ["dist/**"],
            "dependsOn": ["^build-libs:dev"]
        },
        "type-check": {
            "dependsOn": ["build", "^type-check"]
        },
        "lint": {
            "dependsOn": ["build", "^lint"]
        },
        "format": {
            "dependsOn": ["build"]
        },
        "dev": {
            "persistent": true,
            "cache": false,
            "dependsOn": ["build-libs:dev"]
        }
    }
}
