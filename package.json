{
  "name": "web-poc-portal",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "type": "module",
  "scripts": {
    "build": "pnpm run --recursive --if-present build",
    "build-libs": "pnpm --filter=!main run --recursive --if-present build",
    "build:dev:watch": "pnpm --filter=!main --recursive --parallel --if-present run build:dev:watch",
    "dev": "pnpm --filter=main run dev",
    "lint": "pnpm run --recursive --parallel --no-bail --if-present lint"
  },
  "devDependencies": {
    "@prettier/plugin-xml": "catalog:",
    "@swissgeo/config-prettier": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-jsdoc": "catalog:",
    "prettier-plugin-packagejson": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:"
  }
}