{
    "name": "web-poc-portal",
    "version": "1.0.0",
    "private": true,
    "description": "",
    "type": "module",
    "scripts": {
        "build": "NODE_OPTIONS='--max-old-space-size=8192' pnpm run --recursive build",
        "build:dev": "pnpm --parallel --if-present run build:dev",
        "build:dev:watch": "pnpm --filter=!main --recursive --parallel --if-present run build:dev:watch",
        "build:prod": "NODE_OPTIONS='--max-old-space-size=8192' pnpm --recursive --if-present run build:prod",
        "build-libs": "pnpm --filter=!main run --recursive --if-present build",
        "clean": "find packages -name 'dist' -type d -exec rm -rf {} + 2>/dev/null || true",
        "dev": "pnpm --filter=main run dev",
        "format": "pnpm run --recursive --parallel --no-bail --if-present format",
        "format:write": "pnpm run --recursive --parallel --no-bail --if-present format:write",
        "lint": "pnpm run --recursive --parallel --no-bail --if-present lint",
        "lint:write": "pnpm run --recursive --parallel --no-bail --if-present lint:write",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui",
        "type-check": "pnpm run --recursive --parallel --no-bail --if-present type-check"
    },
    "dependencies": {
        "@nuxt/ui": "catalog:",
        "pinia": "catalog:",
        "vue": "catalog:"
    },
    "devDependencies": {
        "@prettier/plugin-xml": "catalog:",
        "@swissgeo/config-prettier": "catalog:",
        "@vitejs/plugin-vue": "catalog:",
        "@vue/test-utils": "catalog:",
        "prettier": "catalog:",
        "prettier-plugin-jsdoc": "catalog:",
        "prettier-plugin-packagejson": "catalog:",
        "prettier-plugin-tailwindcss": "catalog:",
        "unplugin-auto-import": "catalog:",
        "vitest": "catalog:"
    },
    "pnpm": {
        "overrides": {
            "stylelint-config-recommended": "^16.0.0"
        }
    }
}
