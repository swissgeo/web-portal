{
  "name": "web-portal",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "type": "module",
  "scripts": {
    "build": "pnpm --recursive --workspace-concurrency=2 run build",
    "build:dev": "pnpm --recursive --if-present run build:dev",
    "build:dev:watch": "pnpm --filter=!main --recursive --parallel --if-present run build:dev:watch",
    "build:prod": "pnpm --recursive --if-present --workspace-concurrency=2 run build:prod",
    "build-libs": "pnpm --filter=!main run --recursive --if-present build",
    "build-libs:dev": "pnpm --filter=!main run --recursive --if-present build:dev",
    "check": "pnpm run format && pnpm run lint && pnpm run type-check",
    "check:write": "pnpm run format:write && pnpm run lint:write && pnpm run type-check",
    "clean": "find packages -name 'dist' -type d -exec rm -rf {} + 2>/dev/null || true",
    "clean:turbo": "find . -name '.turbo' -type d -exec rm -rf {} + 2>/dev/null || true",
    "dev": "pnpm --filter=main run dev",
    "docker:build": "VERSION=\"$(git describe --tags)\"; docker build --build-arg VERSION=${VERSION} --target ${TARGET}  -t web-portal:local-${USER}-${VERSION}${TAG_SUFFIX:-} .",
    "docker:build:dev": "TARGET=dev TAG_SUFFIX=-dev pnpm run docker:build",
    "docker:build:prod": "TARGET=prod pnpm run docker:build",
    "docker:run": "docker run -p 3000:3000 -it --env-file packages/main/.env web-portal:local-${USER}-$(git describe --tags)${TAG_SUFFIX:-}",
    "docker:run:dev": "TAG_SUFFIX=-dev pnpm run docker:run",
    "docker:run:prod": "pnpm run docker:run",
    "format": "pnpm run --parallel --no-bail --if-present format",
    "format:write": "pnpm run --parallel --no-bail --if-present format:write",
    "lint": "pnpm run --parallel --no-bail --if-present lint",
    "lint:write": "pnpm run --parallel --no-bail --if-present lint:write",
    "test": "pnpm run test:unit",
    "test:coverage": "vitest run --coverage",
    "test:integration": "playwright test",
    "test:integration:ci": "playwright test -c playwright.config.ci.ts",
    "test:ui": "vitest --ui",
    "test:unit": "pnpm run --parallel --no-bail --if-present test:unit",
    "type-check": "pnpm run --parallel --no-bail --if-present type-check"
  },
  "dependencies": {
    "@nuxt/ui": "catalog:",
    "pinia": "catalog:",
    "vue": "catalog:"
  },
  "devDependencies": {
    "@playwright/test": "catalog:",
    "@prettier/plugin-xml": "catalog:",
    "@swissgeo/config-prettier": "workspace:*",
    "@swissgeo/config-prettier-old": "npm:@swissgeo/config-prettier@^1.0.0",
    "@vitejs/plugin-vue": "catalog:",
    "@vue/test-utils": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-jsdoc": "catalog:",
    "prettier-plugin-packagejson": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "turbo": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "overrides": {
      "stylelint-config-recommended": "^16.0.0"
    }
  }
}
