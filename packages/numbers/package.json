{
  "name": "@swissgeo/numbers",
  "version": "1.0.2",
  "description": "Numbers utils for SWISSGEO projects.",
  "license": "BSD-3-Clause",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rolldown --config rolldown.config.ts",
    "build:dev": "rolldown --config rolldown.config.ts --environment NODE_ENV:development",
    "build:dev:watch": "rolldown --config rolldown.config.ts --watch --environment NODE_ENV:development",
    "build:int": "rolldown --config rolldown.config.ts --environment NODE_ENV:integration",
    "build:prod": "rolldown --config rolldown.config.ts --environment NODE_ENV:production",
    "format": "prettier --check --ignore-path ../../.prettierignore .",
    "format:write": "prettier --write --ignore-path ../../.prettierignore .",
    "generate-types": "tsc --declaration",
    "lint": "eslint",
    "lint:write": "eslint --fix",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:watch": "vitest watch",
    "type-check": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@swissgeo/log": "workspace:*"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "catalog:",
    "@swissgeo/config-eslint": "workspace:*",
    "@swissgeo/config-typescript": "workspace:*",
    "eslint": "catalog:",
    "rolldown": "catalog:",
    "rolldown-plugin-dts": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
