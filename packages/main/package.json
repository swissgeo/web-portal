{
  "name": "main",
  "private": true,
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    ".compile-otel": "vue-tsc --ignoreConfig server/instrumentation.ts --target es2022 --module esnext --moduleResolution bundler --outDir .output/server && mv .output/server/instrumentation.js .output/server/instrumentation.mjs",
    "build": "nuxt build && pnpm run .compile-otel",
    "build:dev": "DEVELOPMENT_BUILD=1 nuxt build && pnpm run .compile-otel",
    "build:prod": "nuxt build && pnpm run .compile-otel",
    "dev": "DEVELOPMENT_BUILD=1 nuxt dev",
    "format": "prettier --check --ignore-path ../../.prettierignore .",
    "format:write": "prettier --write --ignore-path ../../.prettierignore .",
    "generate": "nuxt generate",
    "postinstall": "nuxt prepare",
    "lint": "eslint",
    "lint:write": "eslint --fix",
    "preview": "node --import ./.output/server/instrumentation.mjs ./.output/server/index.mjs",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "type-check": "nuxt typecheck"
  },
  "dependencies": {
    "@chenfengyuan/vue-qrcode": "catalog:",
    "@fontsource/inter": "catalog:",
    "@lucide/vue": "catalog:",
    "@nuxt/eslint": "catalog:",
    "@nuxt/ui": "catalog:",
    "@nuxtjs/i18n": "catalog:",
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/auto-instrumentations-node": "catalog:",
    "@opentelemetry/core": "catalog:",
    "@opentelemetry/exporter-metrics-otlp-grpc": "catalog:",
    "@opentelemetry/exporter-trace-otlp-grpc": "catalog:",
    "@opentelemetry/resources": "catalog:",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-node": "catalog:",
    "@opentelemetry/sdk-trace-base": "catalog:",
    "@opentelemetry/semantic-conventions": "catalog:",
    "@pinia/nuxt": "catalog:",
    "@swissgeo/content": "workspace:*",
    "@swissgeo/coordinates": "workspace:*",
    "@swissgeo/drawing": "workspace:*",
    "@swissgeo/elevation-profile": "workspace:*",
    "@swissgeo/layers": "workspace:*",
    "@swissgeo/log": "workspace:*",
    "@swissgeo/map": "workspace:*",
    "@swissgeo/ogc": "workspace:*",
    "@swissgeo/search": "workspace:*",
