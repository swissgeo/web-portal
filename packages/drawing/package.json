{
    "name": "@swissgeo/drawing",
    "version": "0.0.1",
    "description": "Drawing tools and utilities for map interactions",
    "keywords": [],
    "license": "BSD-3-Clause",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.es.js"
        }
    },
    "module": "./dist/index.es.js",
    "scripts": {
        "build": "vite build",
        "build:dev": "vite build --mode development",
        "build:dev:watch": "vite build --watch --mode development",
        "build:prod": "vite build",
        "format": "prettier --check --ignore-path ../../.prettierignore .",
        "format:write": "prettier --write   --ignore-path ../../.prettierignore .",
        "lint": "eslint",
        "lint:write": "eslint --fix",
        "test:unit": "vitest run"
    },
    "dependencies": {
        "@swissgeo/coordinates": "workspace:*",
        "@swissgeo/layers": "workspace:*",
        "@swissgeo/log": "workspace:*",
        "@swissgeo/map": "workspace:*",
        "@swissgeo/shared": "workspace:*",
        "fflate": "catalog:",
        "ol": "catalog:",
        "proj4": "catalog:"
    },
    "devDependencies": {
        "@microsoft/api-extractor": "catalog:",
        "@swissgeo/config-eslint": "workspace:*",
        "@swissgeo/config-prettier": "workspace:*",
        "@swissgeo/config-typescript": "workspace:*",
        "@vitejs/plugin-vue": "catalog:",
        "eslint": "catalog:",
        "prettier": "catalog:",
        "happy-dom": "catalog:",
        "typescript": "catalog:",
        "unplugin-dts": "catalog:",
        "vite": "catalog:",
        "vite-tsconfig-paths": "catalog:",
        "vue-tsc": "catalog:"
    },
    "peerDependencies": {
        "@vueuse/core": "catalog:",
        "lucide-vue-next": "catalog:",
        "vue": "catalog:",
        "vue-i18n": "catalog:"
    },
    "packageManager": "pnpm@10.30.0"
}
