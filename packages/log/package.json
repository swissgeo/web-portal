{
  "name": "@swissgeo/log",
  "version": "1.0.1",
  "description": "Logging utils for SWISSGEO projects.",
  "license": "BSD-3-Clause",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    },
    "./Message": {
      "types": "./dist/Message.d.ts",
      "import": "./dist/Message.js",
      "require": "./dist/Message.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:dev:watch": "vite build --watch --mode development",
    "build:int": "vite build --mode integration",
    "build:prod": "vite build --mode production",
    "format": "prettier --check --ignore-path ../../.prettierignore .",
    "format:write": "prettier --write --ignore-path ../../.prettierignore .",
    "generate-types": "tsc --declaration",
    "lint": "eslint",
    "lint:write": "eslint --fix",
    "type-check": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "catalog:",
    "@swissgeo/config-eslint": "workspace:*",
    "@swissgeo/config-typescript": "workspace:*",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "unplugin-dts": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "proj4": "catalog:"
  }
}
