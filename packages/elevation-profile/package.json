{
  "name": "@swissgeo/elevation-profile",
  "version": "1.0.3",
  "description": "Components to request and display an elevation profile over Switzerland",
  "license": "BSD-3-Clause",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/elevation-profile.js"
    },
    "./stylesheet": [
      "./dist/elevation-profile.css"
    ]
  },
  "scripts": {
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:dev:watch": "vite build --watch --mode development",
    "build:prod": "vite build",
    "format": "prettier --check --ignore-path ../../.prettierignore .",
    "format:write": "prettier --write --ignore-path ../../.prettierignore .",
    "lint": "eslint",
    "lint:write": "eslint --fix",
    "test:unit": "vitest run",
    "type-check": "vue-tsc"
  },
  "dependencies": {
    "@swissgeo/coordinates": "workspace:*",
    "@swissgeo/log": "workspace:*",
    "@swissgeo/numbers": "workspace:*",
    "@swissgeo/shared": "workspace:*",
    "@turf/turf": "catalog:",
    "chart.js": "catalog:",
    "chartjs-plugin-zoom": "catalog:",
    "proj4": "catalog:",
    "vue-chartjs": "catalog:"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "catalog:",
    "@swissgeo/config-eslint": "workspace:*",
    "@swissgeo/config-typescript": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vue/test-utils": "catalog:",
    "eslint": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "unplugin-dts": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vitest": "catalog:",
    "vue-tsc": "catalog:"
  },
  "peerDependencies": {
    "ol": "catalog:",
    "proj4": "catalog:",
    "vue": "catalog:"
  },
  "packageManager": "pnpm@11.3.0"
}
