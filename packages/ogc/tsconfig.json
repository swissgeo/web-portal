{
  "extends": "@swissgeo/config-typescript/tsconfig.base.json",
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "env.d.ts",
    "../../base.vite.config.ts",
    "vitest.config.ts",
  ],
  "exclude": ["vite.config.ts"],
  "compilerOptions": {
    "types": ["vue", "vite/client"],
    "baseUrl": ".",
    "paths": { "@/*": ["src/*"] },
    "declaration": true,
    "isolatedDeclarations": true,
  },
}
