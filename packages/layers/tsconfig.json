{
    "include": [
        "./src/**/*.ts",
        "./src/**/*.d.ts",
        "./src/**/*.vue",
        "./env.d.ts",
        "./.nuxt/auto-imports.d.ts",
        "./.nuxt/auto-components.d.ts"
    ],
    "exclude": ["node_modules", "dist"],
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ESNext", "DOM"],
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "sourceMap": false,
        "outDir": "dist",
        "declaration": true,
        "declarationDir": "dist/types",
        "emitDeclarationOnly": true,
        "jsx": "preserve",
        "allowSyntheticDefaultImports": true,
        "types": ["vue"],
        "paths": {
            "@/*": ["./src/*"]
        },
        "plugins": [{ "name": "@dxup/unimport" }]
    }
}
