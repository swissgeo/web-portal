{
  "name": "@swissgeo/skeleton",
  "version": "0.0.1",
  "description": "",
  "keywords": [],
  "license": "BSD-3-Clause",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js"
    }
  },
  "main": "./dist/index.es.js",
  "module": "./dist/index.es.js",
  "scripts": {
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:dev:watch": "vite build --watch --mode development",
    "build:prod": "vite build",
    "format": "prettier --check --ignore-path ../../.prettierignore .",
    "format:write": "prettier --write --ignore-path ../../.prettierignore .",
    "lint": "eslint",
    "lint:write": "eslint --fix",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.provider=v8 --coverage.reporter=lcov --coverage.reporter=text-summary --coverage.reporter=json-summary --passWithNoTests",
    "type-check": "vue-tsc"
  },
  "dependencies": {
    "@swissgeo/content": "workspace:*",
    "@swissgeo/drawing": "workspace:*",
    "@swissgeo/layers": "workspace:*",
    "@swissgeo/log": "workspace:*",
    "@swissgeo/numbers": "workspace:*",
    "@swissgeo/search": "workspace:*",
    "@swissgeo/shared": "workspace:*",
    "lucide-vue-next": "catalog:"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "catalog:",
    "@swissgeo/config-eslint": "workspace:*",
    "@swissgeo/config-prettier": "workspace:*",
    "@swissgeo/config-typescript": "workspace:*",
    "@swissgeo/ogc": "workspace:*",
    "@vitejs/plugin-vue": "catalog:",
    "@vue/compiler-dom": "catalog:",
    "@vue/server-renderer": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "stylelint": "catalog:",
    "typescript": "catalog:",
    "unplugin-dts": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vue-tsc": "catalog:"
  },
  "peerDependencies": {
    "@nuxt/ui": "catalog:",
    "@vueuse/core": "catalog:",
    "vue": "catalog:",
    "vue-i18n": "catalog:",
    "vue-router": "catalog:"
  },
  "packageManager": "pnpm@10.33.4"
}
