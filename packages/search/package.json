{
  "name": "@swissgeo/search",
  "version": "0.0.1",
  "license": "BSD-3-Clause",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/search.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:dev:watch": "vite build --watch --mode development",
