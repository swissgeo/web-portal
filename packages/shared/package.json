{
  "name": "@swissgeo/shared",
  "version": "0.0.1",
  "description": "",
  "keywords": [],
  "license": "BSD-3-Clause",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./language": {
      "types": "./dist/index.d.ts"
    },
    "./action-dispatcher": {
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "rolldown --config rolldown.config.js",
    "build:dev": "rolldown --config rolldown.config.js --environment NODE_ENV:development",
    "build:dev:watch": "rolldown --config rolldown.config.js --watch --environment NODE_ENV:development",
    "build:prod": "rolldown --config rolldown.config.js",
    "format": "prettier --check --ignore-path ../../.prettierignore .",
    "format:write": "prettier --write --ignore-path ../../.prettierignore .",
    "lint": "eslint",
    "lint:write": "eslint --fix",
    "type-check": "tsc"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "catalog:",
    "@swissgeo/config-eslint": "workspace:*",
    "@swissgeo/config-typescript": "workspace:*",
    "@swissgeo/numbers": "workspace:*",
    "eslint": "catalog:",
    "nuxt": "catalog:",
    "rolldown": "^1.1.0",
    "rolldown-plugin-dts": "^0.25.2",
    "stylelint": "catalog:",
    "typescript": "catalog:",
    "unplugin-dts": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "ol": "catalog:",
    "vue": "catalog:"
  },
  "packageManager": "pnpm@11.6.0"
}
