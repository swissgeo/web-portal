{
  "name": "@swissgeo/shared",
  "version": "0.0.1",
  "description": "",
  "keywords": [],
  "license": "BSD-3-Clause",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js"
    },
    "./ambient": {
      "types": "./dist/ambient/index.d.ts"
    },
    "./api": {
      "types": "./dist/api/index.d.ts"
    },
    "./livingdocs": {
      "types": "./dist/livingdocs/index.d.ts",
      "import": "./dist/index.es.js",
      "default": "./dist/index.es.js"
    },
    "./ogc": {
      "types": "./dist/ogc/index.d.ts"
    },
    "./language": {
      "types": "./dist/language.d.ts"
    },
    "./action-dispatcher": {
      "types": "./dist/actionDispatcher.d.ts"
    },
    "./geojson": {
      "types": "./dist/geojson/index.d.ts"
    }
  },
  "scripts": {
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:dev:watch": "vite build --watch --mode development",
    "build:prod": "vite build",
    "format": "prettier --check --ignore-path ../../.prettierignore .",
    "format:write": "prettier --write --ignore-path ../../.prettierignore .",
    "lint": "eslint",
    "lint:write": "eslint --fix",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.provider=v8 --coverage.reporter=lcov --coverage.reporter=text-summary --coverage.reporter=json-summary --passWithNoTests",
    "type-check": "tsc"
  },
  "dependencies": {
    "nuxt": "catalog:"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "catalog:",
    "@swissgeo/config-eslint": "workspace:*",
    "@swissgeo/config-prettier": "workspace:*",
    "@swissgeo/config-typescript": "workspace:*",
    "@swissgeo/numbers": "workspace:*",
    "@types/mapbox-gl": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "stylelint": "catalog:",
    "typescript": "catalog:",
    "unplugin-dts": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "catalog:"
  },
  "peerDependencies": {
    "ol": "catalog:",
    "vue": "catalog:"
  },
  "packageManager": "pnpm@10.33.4"
}
