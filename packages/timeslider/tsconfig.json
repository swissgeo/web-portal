{
    "extends": "@swissgeo/config-typescript/tsconfig.base.json",
    "compilerOptions": {
        "types": ["vue", "vite/client"],
        "plugins": [{ "name": "@dxup/unimport" }]
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.vue",
        "prettier.config.ts",
        "vite.config.ts",
        "../../base.vite.config.ts",
        ".output/*"
    ],
    "exclude": ["node_modules", "dist"]
}
