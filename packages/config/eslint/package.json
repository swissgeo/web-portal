{
  "name": "@swissgeo/config-eslint",
  "version": "1.0.1",
  "description": "Shared ESLint config for SWISSGEO projects.",
  "repository": {
    "type": "git",
    "url": "https://github.com/swissgeo/web-portal.git",
    "directory": "packages/config/eslint"
  },
  "license": "BSD-3-Clause",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rolldown --config rolldown.config.js",
    "build:dev": "rolldown --config rolldown.config.js --environment NODE_ENV:development",
    "generate-types": "tsc --declaration",
    "lint": "eslint",
    "lint:write": "eslint --fix",
    "type-check": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@eslint/js": "catalog:",
    "@eslint/markdown": "catalog:",
    "@typescript-eslint/utils": "catalog:",
    "@vue/eslint-config-prettier": "catalog:",
    "@vue/eslint-config-typescript": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-mocha": "catalog:",
    "eslint-plugin-perfectionist": "catalog:",
    "eslint-plugin-prettier": "catalog:",
    "eslint-plugin-vue": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "catalog:",
    "@swissgeo/config-typescript": "workspace:*",
    "@types/node": "catalog:",
    "globals": "catalog:",
    "rolldown": "^1.1.0",
    "typescript": "catalog:",
    "unplugin-dts": "catalog:"
  },
  "peerDependencies": {
    "@swissgeo/config-stylelint": "workspace:*",
    "eslint": "catalog:"
  }
}
