{
  "name": "@swissgeo/config-prettier",
  "version": "1.0.1",
  "description": "Shared Prettier config for SWISSGEO projects.",
  "repository": {
    "type": "git",
    "url": "https://github.com/swissgeo/web-portal.git",
    "directory": "packages/config/prettier"
  },
  "license": "BSD-3-Clause",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rolldown --config rolldown.config.js",
    "build:dev": "rolldown --config rolldown.config.js --environment NODE_ENV:development",
    "generate-types": "tsc --declaration",
    "type-check": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "catalog:",
    "@swissgeo/config-typescript": "workspace:*",
    "rolldown": "^1.1.0",
    "typescript": "catalog:",
    "unplugin-dts": "catalog:"
  },
  "peerDependencies": {
    "prettier": "catalog:"
  },
  "optionalDependencies": {
    "@prettier/plugin-xml": "catalog:",
    "prettier-plugin-jsdoc": "catalog:",
    "prettier-plugin-packagejson": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:"
  }
}
