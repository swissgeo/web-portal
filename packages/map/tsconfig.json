{
    "extends": "@swissgeo/config-typescript/tsconfig.base.json",
    "include": [
        "src/**/*.ts",
        "src/**/*.vue",
        "src/**/*.spec.ts",
        "env.d.ts",
        "vite.config.ts",
        "../../base.vite.config.ts"
    ],
    "compilerOptions": {
        "rootDir": "../..",
        "types": ["vue", "./.output/auto-imports.d.ts", "vite/client", "vitest"],
        "plugins": [{ "name": "@dxup/unimport" }],
        "paths": {
            "@/*": ["./src/*", "../skeleton/src/*"],
            "@stores/*": ["./src/stores/*", "../skeleton/src/stores/*"],
            "~/*": ["../main/app/*"]
        }
    },
    "ignoreDeprecations": "6.0"
}
