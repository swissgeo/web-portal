{
  "extends": "@swissgeo/config-typescript/tsconfig.base.json",
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "env.d.ts",
    "types/**/*.d.ts",
    "../../base.vite.config.ts",
    "vitest.config.ts",
  ],
  "compilerOptions": {
    "types": ["vue", "vite/client"],
    "paths": {
      "@/*": ["./src/*", "../skeleton/src/*"],
      "@stores/*": ["./src/stores/*", "../skeleton/src/stores/*"],
    },
    "declaration": true,
    "isolatedDeclarations": true,
  },
}
