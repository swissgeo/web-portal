{
    "extends": "@swissgeo/config-typescript/tsconfig.base.json",
    "include": [
        "src/**/*.ts",
        "src/**/*.vue",
        "env.d.ts",
        "vite.config.ts",
        "types/**/*.d.ts",
        "../../base.vite.config.ts",
        "../main/app/utils/timeUtils.ts"
    ],
    "compilerOptions": {
        "types": ["vue", "vite/client"],
        "paths": {
            "@/*": ["./src/*", "../skeleton/src/*"],
            "@types/*": ["./types/*"],
            "@stores/*": ["./src/stores/*", "../skeleton/src/stores/*"],
            "~/*": ["../main/app/*"]
        }
    },
    "ignoreDeprecations": "6.0"
}
